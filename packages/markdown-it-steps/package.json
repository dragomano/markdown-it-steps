{
  "name": "markdown-it-steps",
  "version": "0.3.1",
  "license": "MIT",
  "description": "Adds a Steps container for use in Markdown.",
  "keywords": [
    "markdown-it",
    "markdown-it-plugin",
    "vitepress-plugin",
    "steps"
  ],
  "author": "Bugo",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./index.js": "./dist/index.js",
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "markdown-it": "^14.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "markdown-it": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "homepage": "https://github.com/dragomano/markdown-it-steps",
  "repository": {
    "type": "git",
    "url": "https://github.com/dragomano/markdown-it-steps.git",
    "directory": "packages/markdown-it-steps"
  },
  "bugs": "https://github.com/dragomano/markdown-it-steps/issues",
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-style.mjs",
    "prepack": "pnpm run build",
    "test": "vitest run"
  }
}
